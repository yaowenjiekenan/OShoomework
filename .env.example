# Qt 环境配置
# 复制此文件为 .env 并修改对应路径

# Qt 安装根目录
QT_DIR=F:\Qt

# Qt bin 目录（包含 qmake.exe）
# Qt 6 llvm-mingw:   <QT_DIR>\6.11.1\6.11.1\llvm-mingw_64\bin
# Qt 6 MSVC:         <QT_DIR>\6.11.1\msvc2019_64\bin
# Qt 5 MinGW:        <QT_DIR>\5.15.2\mingw73_64\bin
QT_BIN=F:\Qt\6.11.1\msvc2019_64\bin

# MinGW bin 目录（包含 mingw32-make.exe）
# Qt 6 llvm-mingw:   <QT_DIR>\6.11.1\Tools\llvm-mingw1706_64\bin
# Qt 5 MinGW:        <QT_DIR>\Tools\mingw73_64\bin
# MSVC 版本不需要 MinGW，可留空
MINGW_BIN=F:\Qt\Tools\mingw73_64\bin
