# Qt 环境配置
# 复制此文件为 .env 并修改对应路径

# Qt 安装根目录（例如：F:\Qt 或 B:\Qt）
QT_DIR=

# Qt bin 目录（包含 qmake.exe）
# 打开文件资源管理器，找到你安装的 Qt 版本下的 bin 文件夹，复制完整路径粘贴到这里
# 示例 Qt 6 llvm-mingw:   <QT_DIR>\6.11.1\6.11.1\llvm-mingw_64\bin
# 示例 Qt 6 MSVC:         <QT_DIR>\6.11.1\msvc2019_64\bin
# 示例 Qt 5 MinGW:        <QT_DIR>\5.15.2\mingw73_64\bin
QT_BIN=

# MinGW bin 目录（包含 mingw32-make.exe）
# 打开文件资源管理器，找到你安装的 MinGW 或 llvm-mingw 工具链下的 bin 文件夹，复制完整路径粘贴到这里
# 如果使用 MSVC 版本的 Qt，此项可留空
# 示例 Qt 6 llvm-mingw:   <QT_DIR>\6.11.1\Tools\llvm-mingw1706_64\bin
# 示例 Qt 5 MinGW:        <QT_DIR>\Tools\mingw73_64\bin
MINGW_BIN=
